{
  "name": "sss-ims-platform",
  "version": "1.0.0",
  "description": "SSS 基础信息管理系统 - NestJS + Vue 3 + PostgreSQL",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,vue,js,json,md}\"",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:generate": "pnpm --filter server db:generate",
    "db:studio": "pnpm --filter server db:studio",
    "db:seed": "pnpm --filter server db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
